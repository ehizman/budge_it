# ── DATABASE ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=relab_budget
DB_USERNAME=relab
DB_PASSWORD=relab_pass

# ── REDIS ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ──────────────────────────────────────────────────────
# REQUIRED: Must be at least 64 characters
JWT_SECRET=replace-this-with-a-secure-64-char-minimum-random-string-in-production!!

# ── SPRING AI — OPENAI ───────────────────────────────────
OPEN_AI_KEY=replace-with-your-open-ai-key-here
# ── WEBHOOK ─────────────────────────────────────────────────
# Shared secret with ReLab MFB for HMAC-SHA256 webhook validation
WEBHOOK_HMAC_SECRET=replace-with-your-webhook-secret

# ── SPRING PROFILE ──────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev
